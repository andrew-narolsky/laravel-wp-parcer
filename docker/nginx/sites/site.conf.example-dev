server {
    listen 80;
    server_name localhost;
    return 301 https://localhost$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name localhost;

    ssl_certificate /var/www/letsencrypt/localhost+2.pem;
    ssl_certificate_key /var/www/letsencrypt/localhost+2-key.pem;

    include /etc/nginx/sites-available/defaults/general.conf;
    include /etc/nginx/sites-available/defaults/ssl.conf;
}
